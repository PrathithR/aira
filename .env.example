# AIRA — Environment Variables
# Full setup guide: docs/setup.md

# Environment
APP_ENV=dev     # dev | production

# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Google OAuth — see docs/setup.md#google-oauth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/callback

# Encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_encryption_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/aira.db

# Notifications — see docs/setup.md#notifications
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=your_ntfy_topic_here

# Timezone
DEFAULT_TIMEZONE=America/New_York
